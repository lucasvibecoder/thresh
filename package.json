{
  "name": "thresh",
  "private": true,
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i src/input.css -o output.css --minify",
    "build:playbooks": "node playbooks/_build/build.js",
    "build": "npm run build:css && npm run build:playbooks",
    "dev": "npx @tailwindcss/cli -i src/input.css -o output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}
